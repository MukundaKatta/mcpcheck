{
  "name": "mcpcheck",
  "version": "1.0.0",
  "description": "Validate MCP (Model Context Protocol) config files for Claude, Cursor, Cline, Windsurf, and Zed. CLI + GitHub Action with SARIF output.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mcpcheck": "dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js",
    "dev": "tsc -w",
    "test": "tsx --test tests/**/*.test.ts",
    "lint": "tsc --noEmit",
    "docs:gen": "node scripts/gen-rules-md.mjs",
    "docs:check": "node scripts/gen-rules-md.mjs && git diff --exit-code -- docs/RULES.md",
    "prepublishOnly": "npm run build && npm test && npm run docs:check"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "cursor",
    "cline",
    "windsurf",
    "zed",
    "linter",
    "validator",
    "github-action",
    "cli",
    "sarif"
  ],
  "author": "Mukunda Katta",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MukundaKatta/mcpcheck.git"
  },
  "bugs": {
    "url": "https://github.com/MukundaKatta/mcpcheck/issues"
  },
  "homepage": "https://github.com/MukundaKatta/mcpcheck#readme",
  "dependencies": {
    "commander": "^12.1.0",
    "globby": "^14.0.2",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "action.yml",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ]
}
